# 1. Gmail SMTP 
# SENDER: 메일 송신자의 이메일 주소 작성
# GOOGLE_APP_PASSWORD 발급 방법: [Google 계정 - 보안 - 앱 비밀번호]
# 다른 방법)
# 1. https://myaccount.google.com/apppasswords 접속. 
# 2. 앱 이름 작성 후 앱 비밀번호 발급(메모장 등에 반드시 저장해 놓을 것.).
SENDER=your_email@gmail.com
GOOGLE_APP_PASSWORD=your_google_app_password

# 2. 네이버 검색 API 
# 발급 방법: https://developers.naver.com 에서 애플리케이션 등록 후 발급 (ID와 Secret 모두 필요)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 4. 구독자 API 관리자 인증
# GET /subscribers(전체 구독자 조회)를 호출하려면 프론트가 이 값을 X-Admin-Password 헤더로 보내야 한다.
# 미설정 시 그 엔드포인트는 항상 401을 반환한다(안전 기본값).
ADMIN_PASSWORD=change_this_admin_password


# 5. API 주소
# 프론트가 이 API를 호출할 때 쓰는 주소이자, 구독 확인 메일의 링크(GET /confirm?token=...)를
# 만들 때도 쓰인다. 배포 시 실제 접근 가능한 주소로 바꿀 것(로컬은 기본값 그대로 둬도 됨).
API_BASE_URL="http://localhost:8000"

# 5-1. 프론트엔드(Streamlit) 주소
# report.py 가 뉴스레터 메일 하단의 구독취소/발송 설정 링크를 만들 때 쓴다.
# 배포 시 실제 프론트엔드 접근 주소로 바꿀 것(로컬은 기본값 그대로 둬도 됨).
FRONTEND_BASE_URL="http://localhost:8501"

# 6. LLM/Agent (뉴스 요약·QA)
# OpenRouter(https://openrouter.ai/keys)에서 발급받은 키를 넣는다 — OpenAI SDK 형식을
# 그대로 쓰되 base_url 만 OpenRouter로 향하므로, 변수명은 OPENAI_API_KEY 그대로 사용한다.
OPENAI_API_KEY=your_openrouter_api_key
